# My tmux configuration, partly based on https://github.com/wbkang/wbk-stow/blob/master/tmux-config/.tmux.conf

# Scroll History
set -g history-limit 50000

# show messages for 4 seconds instead
set -g display-time 4000

# set first window to index 1 (not 0) to map more to the keyboard layout
set-option -g renumber-windows on
set -g base-index 1
setw -g pane-base-index 1
# Set the color of the active pane border to red
set -g pane-active-border-style "fg=red"
set -g pane-active-border-style fg=colour208,bg=default

# Optional: Set the color of inactive pane borders (e.g., to a muted color like blue)
set -g pane-border-style "fg=green"
set -g pane-border-lines heavy

# Make mouse useful, tmux > 2.1 include select, resize pane/window and console wheel scroll
setw -g mouse on
unbind-key -T copy-mode MouseDragEnd1Pane
unbind-key -T copy-mode-vi MouseDragEnd1Pane

# Add vi mode
set-window-option -g mode-keys vi

## COPY SET TO CLIPBOARD
# Mac opt
# bind-key -T copy-mode-vi y send-keys -X copy-selection
# Linux opt - Use xclip
setw -g mode-keys vi
set -s set-clipboard off
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel 'xclip -selection clipboard -in >/dev/null'
